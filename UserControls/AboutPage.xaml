<UserControl x:Class="UClipClip.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppBgBrush}">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="📋 UClipClip" FontSize="28" FontWeight="Bold"
                   Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <TextBlock Text="Version 1.0" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <TextBlock Text="A smart clipboard manager for Windows." TextWrapping="Wrap"
                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <TextBlock Text="© 2025 UClipClip Team" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,30"/>

        <Button Content="← Back" Click="BackButton_Click" Width="100" Height="32"
                Background="{DynamicResource SurfaceBgBrush}"
                Foreground="{DynamicResource TextPrimaryBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                Cursor="Hand" HorizontalAlignment="Center"/>
    </StackPanel>
</UserControl>