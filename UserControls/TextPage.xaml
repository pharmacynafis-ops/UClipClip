<UserControl x:Class="UClipClip.TextPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Copied Text" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Modern Navigation Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="FilterAll" Content="All" Width="60" Margin="0,0,10,0" 
                    Click="FilterButton_Click" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="1"
                    Cursor="Hand" Padding="5" FontWeight="Bold"/>
            <Button x:Name="FilterToday" Content="Today" Width="60" Margin="0,0,10,0" 
                    Click="FilterButton_Click" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="1"
                    Cursor="Hand" Padding="5"/>
            <Button x:Name="FilterWeek" Content="This Week" Width="80" 
                    Click="FilterButton_Click" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="1"
                    Cursor="Hand" Padding="5"/>
        </StackPanel>

        <!-- Scrollable list of expandable cards -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="TextItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Background="White">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Card Header (click to expand/collapse) -->
                                <Border Background="#F8F8F8" CornerRadius="8,8,0,0" Padding="10" 
                                        MouseLeftButtonDown="CardHeader_Click" Tag="{Binding}">
                                    <Grid>
                                        <TextBlock Text="{Binding ShortContent}" FontWeight="SemiBold" 
                                                   TextTrimming="CharacterEllipsis" Margin="0,0,30,0"/>
                                        <TextBlock HorizontalAlignment="Right" Text="▶" FontSize="12" 
                                                   Foreground="Gray" x:Name="ExpandIcon"/>
                                    </Grid>
                                </Border>

                                <!-- Expanded Content (hidden when collapsed) -->
                                <Border Grid.Row="1" Visibility="Collapsed" x:Name="ExpandedContent" Padding="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Copy" Width="60" Margin="0,0,8,0" 
                                                    Click="CopyButton_Click" Tag="{Binding}" Background="#0078D4" 
                                                    Foreground="White" BorderThickness="0" Padding="5"/>
                                            <Button Content="Edit" Width="60" 
                                                    Click="EditButton_Click" Tag="{Binding}" Background="#666" 
                                                    Foreground="White" BorderThickness="0" Padding="5"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Edit panel (full‑screen overlay) -->
        <Border x:Name="EditPanel" Grid.RowSpan="3" Background="White" Visibility="Collapsed" CornerRadius="8">
            <StackPanel Margin="10">
                <TextBlock Text="Edit Text" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBox x:Name="EditTextBox" Height="100" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Save" Width="60" Margin="0,0,8,0" Click="SaveEdit_Click" Background="#0078D4" Foreground="White" Padding="5"/>
                    <Button Content="Cancel" Width="60" Click="CancelEdit_Click" Background="#666" Foreground="White" Padding="5"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>