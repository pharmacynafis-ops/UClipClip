<Window x:Class="UClipClip.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UClipClip" Height="450" Width="300"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True"
        Loaded="Window_Loaded">
    <Border Background="White" CornerRadius="10" BorderBrush="#ccc" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Drag area (title bar) -->
        <Border Background="Transparent" Height="30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>

        <!-- Tab Header -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,10,10,0">
            <RadioButton x:Name="TabText" Content="Text" GroupName="Tabs" IsChecked="True" Checked="Tab_Checked" Margin="0,0,10,0"/>
            <RadioButton x:Name="TabFiles" Content="Files &amp; Folders" GroupName="Tabs" Checked="Tab_Checked" Margin="0,0,10,0"/>
            <RadioButton x:Name="TabSettings" Content="Settings" GroupName="Tabs" Checked="Tab_Checked"/>
        </StackPanel>

        <!-- Tab Content -->
        <Grid Grid.Row="1" Margin="10" Grid.RowSpan="2">
            <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden"/>
        </Grid>

        <!-- Close button -->
        <Button Grid.Row="2" Content="✕" Width="30" Height="30" HorizontalAlignment="Right" 
                Margin="0,0,10,10" Click="CloseButton_Click" Background="Transparent" BorderThickness="0"
                FontSize="14" Cursor="Hand"/>
    </Grid>
</Border>
</Window>