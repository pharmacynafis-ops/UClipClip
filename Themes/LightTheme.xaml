<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Light (default) ──────────────────────────────────────────── -->
    <Color x:Key="AppBg">#FFFFFF</Color>
    <Color x:Key="SurfaceBg">#F5F7FA</Color>
    <Color x:Key="CardBg">#FFFFFF</Color>
    <Color x:Key="CardBorder">#E2E8F0</Color>
    <Color x:Key="TitleBarBg">#F0F4FF</Color>
    <Color x:Key="Accent">#4F6EF7</Color>
    <Color x:Key="AccentHover">#3A56E0</Color>
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="TextPrimary">#1A202C</Color>
    <Color x:Key="TextSecondary">#64748B</Color>
    <Color x:Key="TabActive">#4F6EF7</Color>
    <Color x:Key="TabActiveText">#FFFFFF</Color>
    <Color x:Key="TabInactive">#EEF2FF</Color>
    <Color x:Key="TabInactiveText">#4F6EF7</Color>
    <Color x:Key="InputBg">#FFFFFF</Color>
    <Color x:Key="InputBorder">#CBD5E1</Color>
    <Color x:Key="ScrollBg">#E2E8F0</Color>
    <Color x:Key="PinColor">#F59E0B</Color>
    <Color x:Key="SettingsBtnBg">#4F6EF7</Color>
    <Color x:Key="WindowBorder">#C7D2FE</Color>

    <SolidColorBrush x:Key="AppBgBrush"            Color="{StaticResource AppBg}"/>
    <SolidColorBrush x:Key="SurfaceBgBrush"        Color="{StaticResource SurfaceBg}"/>
    <SolidColorBrush x:Key="CardBgBrush"           Color="{StaticResource CardBg}"/>
    <SolidColorBrush x:Key="CardBorderBrush"       Color="{StaticResource CardBorder}"/>
    <SolidColorBrush x:Key="TitleBarBgBrush"       Color="{StaticResource TitleBarBg}"/>
    <SolidColorBrush x:Key="AccentBrush"           Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"      Color="{StaticResource AccentHover}"/>
    <SolidColorBrush x:Key="DangerBrush"           Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"      Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"    Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TabActiveBrush"        Color="{StaticResource TabActive}"/>
    <SolidColorBrush x:Key="TabActiveTextBrush"    Color="{StaticResource TabActiveText}"/>
    <SolidColorBrush x:Key="TabInactiveBrush"      Color="{StaticResource TabInactive}"/>
    <SolidColorBrush x:Key="TabInactiveTextBrush"  Color="{StaticResource TabInactiveText}"/>
    <SolidColorBrush x:Key="InputBgBrush"          Color="{StaticResource InputBg}"/>
    <SolidColorBrush x:Key="InputBorderBrush"      Color="{StaticResource InputBorder}"/>
    <SolidColorBrush x:Key="ScrollBgBrush"         Color="{StaticResource ScrollBg}"/>
    <SolidColorBrush x:Key="PinColorBrush"         Color="{StaticResource PinColor}"/>
    <SolidColorBrush x:Key="SettingsBtnBgBrush"    Color="{StaticResource SettingsBtnBg}"/>
    <SolidColorBrush x:Key="WindowBorderBrush"     Color="{StaticResource WindowBorder}"/>
</ResourceDictionary>
